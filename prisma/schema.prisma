generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  passwordHash    String
  role            String           // "employer" or "worker"
  skills          String[]
  location        String?
  phone           String?
  bio             String?
  avatar          String?
  portfolio       String[]
  rating          Float?
  createdAt       DateTime         @default(now())

  // Security & Verification
  emailVerified         Boolean   @default(false)
  verificationToken     String?   @unique
  verificationExpires   DateTime?
  resetPasswordToken    String?   @unique
  resetPasswordExpires DateTime?

  serviceRequests ServiceRequest[] @relation("EmployerRequests")
  assignedTasks   ServiceRequest[] @relation("WorkerTasks")
  sentMessages    Message[]        @relation("SentMessages")
  receivedMessages Message[]       @relation("ReceivedMessages")
  reviewsReceived Review[]         @relation("WorkerReviews")
  reviewsGiven    Review[]         @relation("EmployerReviews")
  notifications   Notification[]
  availability    WorkerAvailability?
  applications    JobApplication[] @relation("WorkerApplications")
  offersReceived  ServiceOffer[]   @relation("WorkerOffers")
  offersSent      ServiceOffer[]   @relation("EmployerOffers")
}

model WorkerAvailability {
  id            String   @id @default(uuid())
  workerId      String   @unique
  category      String
  subcategories String[]
  wilayas       String[]
  title         String
  description   String
  hourlyRate    Float
  dailyRate     Float?
  type          String?   // "now", "part", "full"
  startTime     String?
  endTime       String?
  isAvailable   Boolean  @default(true)
  createdAt     DateTime @default(now())

  worker        User     @relation(fields: [workerId], references: [id])
  offers        ServiceOffer[]
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model ServiceRequest {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String
  subcategory String?
  location    String
  budget      String
  wilaya      String
  status      String   @default("open") // "open", "assigned", "completed"
  employerId  String
  workerId    String?
  createdAt   DateTime @default(now())

  employer    User     @relation("EmployerRequests", fields: [employerId], references: [id])
  worker      User?    @relation("WorkerTasks", fields: [workerId], references: [id])
  review      Review?
  applications JobApplication[]
  offers       ServiceOffer[]
}

model JobApplication {
  id          String   @id @default(uuid())
  requestId   String
  workerId    String
  price       String
  description String
  status      String   @default("pending") // "pending", "accepted", "rejected"
  createdAt   DateTime @default(now())

  request ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  worker  User           @relation("WorkerApplications", fields: [workerId], references: [id], onDelete: Cascade)
}

model ServiceOffer {
  id             String   @id @default(uuid())
  employerId     String
  workerId       String
  availabilityId String
  requestId      String?
  status         String   @default("pending") // "pending", "accepted", "rejected"
  createdAt      DateTime @default(now())

  employer     User                @relation("EmployerOffers", fields: [employerId], references: [id], onDelete: Cascade)
  worker       User                @relation("WorkerOffers", fields: [workerId], references: [id], onDelete: Cascade)
  availability WorkerAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)
  request      ServiceRequest?    @relation(fields: [requestId], references: [id], onDelete: SetNull)
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  text       String
  timestamp  DateTime @default(now())
  isRead     Boolean  @default(false)

  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model Review {
  id         String   @id @default(uuid())
  workerId   String
  employerId String
  requestId  String   @unique
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  worker     User           @relation("WorkerReviews", fields: [workerId], references: [id])
  employer   User           @relation("EmployerReviews", fields: [employerId], references: [id])
  request    ServiceRequest @relation(fields: [requestId], references: [id])
}
